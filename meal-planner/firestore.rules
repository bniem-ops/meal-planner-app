rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔒 REPLACE THESE WITH YOUR TWO GOOGLE ACCOUNT EMAILS
    function isAllowed() {
      return request.auth != null &&
        request.auth.token.email in [
          'brentcniemerski@gmail.com',
          'ebniemerski@gmail.com',
          'elizabethniemerski@gmail.com'
        ];
    }

    match /mealPlans/{weekId} {
      allow read, write: if isAllowed();
    }
    
    match /customRecipes/{recipeId} {
      allow read, write: if isAllowed();
    }
    
    match /grocery/{docId} {
      allow read, write: if isAllowed();
    }
    
    match /mealData/{docId} {
      allow read, write: if isAllowed();
    }

    match /weeklyReviews/{weekId} {
      allow read, write: if isAllowed();
    }

    // Recipe comments subcollection
    match /recipeComments/{recipeId}/comments/{commentId} {
      allow read, write: if isAllowed();
    }
    
    // weeklyReviews nested under mealData
    // Path: mealData/weeklyReviews/{weekId}/review
    match /mealData/weeklyReviews/{weekId}/{docId} {
      allow read, write: if isAllowed();
    }
  }
}
